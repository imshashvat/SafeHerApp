# SafeHer Frontend Environment Variables
# Copy this to .env and fill in your actual values

# ─── API URL ─────────────────────────────────────────────────────────────────
# Leave empty for local dev (Vite proxy handles it)
# For production: set to your Render backend URL e.g. https://safeher-api.onrender.com
VITE_API_URL=

# ─── EmailJS ─────────────────────────────────────────────────────────────────
# Free account: https://www.emailjs.com
# 1. Create account → Email Services → Add Gmail → copy Service ID below
# 2. Email Templates → New Template (use variables: to_email, to_name,
#    location_url, latitude, longitude, timestamp, from_name)
# 3. Account → API Keys → copy Public Key below
VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY

# ─── Firebase ────────────────────────────────────────────────────────────────
# Free project: https://console.firebase.google.com
# Steps:
#   1. Create a new project → Register a Web App → copy config below
#   2. Authentication → Sign-in method → Enable Email/Password
#   3. Firestore Database → Create database → Start in test mode
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
