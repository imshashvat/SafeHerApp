# SafeHer Backend — Environment Variables Example
# Copy this file to .env and replace with your actual values

# ─── SMTP Email Configuration ────────────────────────────────────────────────
# Used for sending SOS emails from the backend.
# Recommended: Use a free Gmail account.
# Note: You MUST use an "App Password" if 2-Factor Authentication is enabled.
# How to get an App Password: 
# 1. Manage your Google Account -> Security
# 2. 2-Step Verification -> App Passwords
# 3. Create a new App Password (e.g. for "SafeHer App") and paste it below.

SMTP_EMAIL=your.email@gmail.com
SMTP_PASSWORD=your_16_character_app_password
